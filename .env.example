# Stillness Local Development Configuration
# Copy this file to .env and configure the required values
#
# Quick Start:
#   1. Copy: cp .env.example .env
#   2. Set ANTHROPIC_API_KEY (required)
#   3. Run: ./dev.sh or make dev

# ============================================================================
# REQUIRED: LLM Provider
# ============================================================================

# Anthropic API Key (REQUIRED)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# OpenAI API Key (optional, for GPT models)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Model Selection (affects cost and quality)
# - claude-sonnet-4-20250514    (~$1.50-2.50 per call) - Best quality, recommended
# - claude-3-5-sonnet-latest    (~$1.00-2.00 per call) - Good balance (if available)
# Note: Some API keys may only have access to Claude 4 models
MODEL_NAME=claude-sonnet-4-20250514

# ============================================================================
# OPTIONAL: LiteLLM Proxy (Docker Compose setup)
# ============================================================================

# Set to true when using Docker Compose (routes through LiteLLM proxy)
USE_LITELLM=false

# LiteLLM settings (used when USE_LITELLM=true)
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=dummy

# ============================================================================
# OPTIONAL: Gong Integration
# ============================================================================

# Gong API credentials for fetching call transcripts
# Get from: Gong Settings > API (requires Technical Admin)
GONG_ACCESS_KEY=
GONG_SECRET_KEY=

# Gong MCP server URL (used by API to fetch transcripts)
# Default for Docker: http://gong-mcp:8080
# Default for local: leave empty (uses direct Gong API)
GONG_MCP_URL=

# ============================================================================
# OPTIONAL: BigQuery (for Prospect Overview, CRM analytics)
# ============================================================================

# Google Cloud Project ID
GOOGLE_CLOUD_PROJECT=mkt-analytics-268801

# Authentication options:
# 1. Local dev: Run `gcloud auth application-default login`
# 2. Service account: Set GOOGLE_APPLICATION_CREDENTIALS path
# 3. Docker/CI: Set GCP_CREDENTIALS_BASE64 (base64-encoded service account JSON)

# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GCP_CREDENTIALS_BASE64=

# ============================================================================
# OPTIONAL: Hypothesis Research (Web Search)
# ============================================================================

# Brave Search API key for hypothesis research feature
# Get from: https://brave.com/search/api/
BRAVE_API_KEY=

# LLM model for hypothesis tool
LLM_MODEL=claude-sonnet-4-20250514

# ============================================================================
# OPTIONAL: Observability (Arize AX)
# ============================================================================

# Arize AX for OpenInference tracing
# Sign up at: https://arize.com/
ARIZE_API_KEY=
ARIZE_SPACE_ID=
ARIZE_PROJECT_NAME=stillness-local

# Debug tracing output
ARIZE_TRACE_DEBUG=0

# Span processor settings
ARIZE_ENABLE_OUTPUT_CLEANING=true
ARIZE_MAX_OUTPUT_LENGTH=10000
ARIZE_MAX_INPUT_LENGTH=5000
ARIZE_ENABLE_PII_REDACTION=false
ARIZE_ENABLE_METADATA_ENRICHMENT=true

# ============================================================================
# TELEMETRY SETTINGS (usually leave defaults)
# ============================================================================

# Disable CrewAI's built-in telemetry
OTEL_SDK_DISABLED=false
CREWAI_TELEMETRY_OPT_OUT=true
CREWAI_DISABLE_TELEMETRY=true
CREWAI_TRACING_ENABLED=false
CREWAI_STORAGE_DIR=~/.crewai

# Disable OTEL exporters (we use Arize)
OTEL_TRACES_EXPORTER=none
OTEL_METRICS_EXPORTER=none
OTEL_LOGS_EXPORTER=none

# LiteLLM settings
LITELLM_DROP_PARAMS=true

# ============================================================================
# POC/POT DOCUMENT GENERATION
# ============================================================================

# LLM model for PoC/PoT Word document generation (template filling)
# Faster models reduce generation time significantly:
#   - gpt-4o-mini        (~3-5s)  - Fast, good quality, recommended for speed
#   - claude-haiku-4-5   (~5-8s)  - Default, good balance of speed and quality
#   - claude-sonnet-4    (~10-15s) - Highest quality but slower
# Set to "gpt-4o-mini" for faster PoC generation (requires OPENAI_API_KEY)
POC_DOC_LLM_MODEL=claude-haiku-4-5

# Max tokens for PoC document LLM response (default: 12288)
# Reduce this if responses are being truncated or to speed up generation
POC_DOC_MAX_TOKENS=12288

# Max chars from ProspectOverview to include in LLM prompt (default: 75000)
# Reducing this speeds up generation but may omit some account context
POC_DOC_MAX_PROMPT_CHARS=75000

# Debug mode - prints LLM responses to console
POC_DOC_DEBUG=0

# ============================================================================
# PERFORMANCE / CACHING
# ============================================================================

# Prospect overview cache TTL in seconds (default: 900 = 15 minutes)
# Cached data is reused when clicking multiple capabilities for same account
PROSPECT_CACHE_TTL_SECONDS=900

# Max number of cached prospect overviews (default: 100)
PROSPECT_CACHE_MAX_SIZE=100

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# Server port (API runs on this port)
PORT=8080

# When set, GET / on the API host redirects browsers to this URL (the Next.js Stillness app).
# Docker Compose sets STILLNESS_WEB_URL=http://localhost:${WEB_PORT:-3000} on the api service.
# STILLNESS_WEB_URL=http://localhost:3000

# Environment name
ENVIRONMENT=development
APP_VERSION=1.0.0
