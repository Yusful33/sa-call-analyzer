# Copy to secret.yaml and fill in real values. Do not commit secret.yaml.
# kubectl apply -f k8s/secret.yaml
#
# Generate GCP_CREDENTIALS_BASE64:
#   base64 -w0 /path/to/your-service-account.json
apiVersion: v1
kind: Secret
metadata:
  name: id-pain-secrets
  namespace: id-pain
type: Opaque
stringData:
  ARIZE_API_KEY: "<your-arize-api-key>"
  ARIZE_SPACE_ID: "<your-arize-space-id>"
  ANTHROPIC_API_KEY: "<your-anthropic-api-key>"
  OPENAI_API_KEY: "<your-openai-api-key-or-dummy-if-using-anthropic>"
  # Optional: Gong integration
  GONG_ACCESS_KEY: "<your-gong-access-key>"
  GONG_SECRET_KEY: "<your-gong-secret-key>"
  # GCP BigQuery: base64-encoded service account JSON (same as Railway GCP_CREDENTIALS_BASE64)
  GCP_CREDENTIALS_BASE64: "<base64-encoded-google-service-account-json>"
