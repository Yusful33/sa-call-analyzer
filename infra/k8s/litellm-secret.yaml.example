# Copy to litellm-secret.yaml and fill in. Do not commit litellm-secret.yaml.
# kubectl apply -f k8s/litellm-secret.yaml
apiVersion: v1
kind: Secret
metadata:
  name: litellm-secrets
  namespace: id-pain
type: Opaque
stringData:
  ANTHROPIC_API_KEY: "<your-anthropic-api-key>"
  OPENAI_API_KEY: "<your-openai-api-key>"
