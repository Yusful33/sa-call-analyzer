# Copy to gong-secret.yaml and fill in. Do not commit gong-secret.yaml.
# kubectl apply -f k8s/gong-secret.yaml
apiVersion: v1
kind: Secret
metadata:
  name: gong-secrets
  namespace: id-pain
type: Opaque
stringData:
  GONG_ACCESS_KEY: "<your-gong-access-key>"
  GONG_SECRET_KEY: "<your-gong-secret-key>"
