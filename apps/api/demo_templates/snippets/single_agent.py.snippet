# ─── single_agent emitters ───────────────────────────────────────────────────

AGENT_NAME = "{{AGENT_NAME}}"  # e.g. "customer_service_agent", "fraud_triage_agent"
CHAIN_ROOT_NAME = "invocation [{{COMPANY_SLUG}}-agent]"


def _emit_tool(tracer, tool_call, session_id, *, failed=False):
    with tracer.start_as_current_span(tool_call["name"]) as span:
        _set_tool_attrs(span, tool_name=tool_call["name"],
                        input_val=tool_call.get("input", {}),
                        output_val=tool_call.get("output", {}))
        _annotate_session(span, session_id)
        span.set_attribute("latency_ms", round(random.uniform(50, 400), 2))
        if failed:
            _mark_error(span, "ToolExecutionError", tool_call.get("error", "Tool call failed"))
        else:
            span.set_status(Status(StatusCode.OK))


def _emit_llm_call(tracer, scenario, *, role, session_id, is_poisoned=False, user_msg=None, assistant_msg=None):
    template_name = next(iter(PROMPT_TEMPLATES)) if PROMPT_TEMPLATES else None
    template = PROMPT_TEMPLATES.get(template_name, {}) if template_name else {}
    version = scenario.get("prompt_version", template.get("version", "v1.0"))
    system_msg = template.get("system_message")
    template_str = template.get("template", "{user_query}")

    user_msg = user_msg or template_str.format(user_query=scenario.get("question", ""))
    assistant_msg = assistant_msg or scenario.get("answer", "")

    with tracer.start_as_current_span(LLM_SPAN_NAME) as span:
        _set_llm_attrs(
            span,
            system_msg=system_msg,
            user_msg=user_msg,
            assistant_msg=assistant_msg,
            template=template_str,
            template_version=version,
            template_vars={"user_query": scenario.get("question", "")[:200]},
            is_poisoned=is_poisoned,
        )
        _annotate_session(span, session_id)
        span.set_attribute("latency_ms", round(random.uniform(500, 2000), 2))
        span.set_status(Status(StatusCode.OK))
        return _span_id(span)


def _emit_agent(tracer, scenario, session_id):
    with tracer.start_as_current_span(f"agent_run [{AGENT_NAME}]") as agent:
        _set_kind(agent, "AGENT")
        agent.set_attribute("agent.name", AGENT_NAME)
        _set_io(agent, scenario.get("question", ""), None)
        _annotate_session(agent, session_id)
        agent_sid = _span_id(agent)

        stype = scenario["type"]
        is_poisoned = scenario.get("is_poisoned", False)

        if stype == "no_llm_needed":
            _emit_llm_call(tracer, scenario, role="direct", session_id=session_id, is_poisoned=is_poisoned)
            final = scenario.get("answer", "")

        elif stype == "tool_failure":
            tool_calls = scenario.get("tool_calls", [])
            if tool_calls:
                _emit_tool(tracer, {**tool_calls[0], "error": "Downstream service unavailable"}, session_id, failed=True)
                for tc in tool_calls[1:]:
                    _emit_tool(tracer, tc, session_id)
            _emit_llm_call(tracer, scenario, role="respond", session_id=session_id, is_poisoned=is_poisoned,
                          assistant_msg="I encountered an error. " + scenario.get("answer", ""))
            final = "(handled tool failure)"

        elif stype == "execution_failure":
            for tc in scenario.get("tool_calls", []):
                _emit_tool(tracer, tc, session_id)
            with tracer.start_as_current_span("final_action") as fa:
                _set_kind(fa, "TOOL")
                fa.set_attribute("tool.name", "final_action")
                _set_io(fa, scenario.get("question"), None)
                _annotate_session(fa, session_id)
                _mark_error(fa, "ExecutionTimeout", "Action timed out after 30s")
            final = "(execution failed)"

        elif stype == "retry":
            tool_calls = scenario.get("tool_calls", [])
            if tool_calls:
                first = {**tool_calls[0], "error": "TransientTimeout"}
                _emit_tool(tracer, first, session_id, failed=True)
                _emit_tool(tracer, tool_calls[0], session_id)  # retry succeeds
                for tc in tool_calls[1:]:
                    _emit_tool(tracer, tc, session_id)
            _emit_llm_call(tracer, scenario, role="respond", session_id=session_id, is_poisoned=is_poisoned)
            final = scenario.get("answer", "")

        else:  # happy_path, poisoned_tokens, ambiguity fallback
            _emit_llm_call(tracer, scenario, role="plan", session_id=session_id, is_poisoned=is_poisoned)
            for tc in scenario.get("tool_calls", []):
                _emit_tool(tracer, tc, session_id)
            _emit_llm_call(tracer, scenario, role="respond", session_id=session_id, is_poisoned=is_poisoned)
            final = scenario.get("answer", "")

        _set_io(agent, None, final)
        agent.set_attribute("latency_ms", round(random.uniform(1500, 8000), 2))
        agent.set_status(Status(StatusCode.OK))
        return final, agent_sid


def create_trace(tracer, scenario, session_id=None):
    span_ids = {"type": scenario["type"]}
    with tracer.start_as_current_span(CHAIN_ROOT_NAME) as root:
        _set_kind(root, "CHAIN")
        _set_io(root, scenario.get("question", ""), None)
        _annotate_session(root, session_id)
        span_ids["root"] = _span_id(root)

        final, agent_sid = _emit_agent(tracer, scenario, session_id)
        span_ids["agent"] = agent_sid

        _set_io(root, None, final)
        root.set_status(Status(StatusCode.OK))

    return span_ids
