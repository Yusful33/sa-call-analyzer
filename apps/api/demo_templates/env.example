# Copy to .env and fill in. Do not commit .env.
# (.env is excluded by the generated .gitignore.)

# Required for trace ingest AND for the `ax` CLI used by --build-dataset / --build-experiments.
ARIZE_SPACE_ID=
ARIZE_API_KEY=
ARIZE_PROJECT_NAME=

# Optional — set to override the default dataset name used by --build-dataset.
# Defaults to "<company_slug>_eval_set".
# ARIZE_DATASET_NAME=

# Optional — re-use an existing dataset id instead of creating a new one.
# ARIZE_DATASET_ID=
